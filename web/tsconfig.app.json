{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],

    /* 路径别名：跟 vite.config.ts 的 alias 配套
       baseUrl 是 paths 解析的基准，"." 指 tsconfig.app.json 所在目录（即 web/）
       paths "@/*": ["src/*"] 等于"@/xx 在 TS 看来 = src/xx"
       这样 IDE 跳转、Cmd+点击 import、类型检查才能跟上 */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}
