# Mini CRM API 测试集合
# 用法：装 VSCode 扩展 "REST Client"（作者 Huachao Mao），每个请求上方会出现 "Send Request" 按钮，点一下就发请求
# ### 三个井号是"请求分隔符"，每个请求一段
# 单个 # 是注释，会被 REST Client 忽略

# 全局变量：基础 URL，下面用 {{baseUrl}} 引用
# 改成生产环境的域名只需要改这一行
@baseUrl = http://localhost:3000

# ============================================================
# D2 - 健康检查
# ============================================================

### 健康检查（确认后端活着）
GET {{baseUrl}}/api/health


# ============================================================
# D3 - 鉴权
# ============================================================

### ① 注册新用户（首次跑 → 200；同邮箱再跑 → 409）
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "123456",
  "name": "中文预发布"
}


### ② 注册参数校验失败（邮箱格式错 → 400）
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "not-an-email",
  "password": "123456"
}


### ③ 登录（拿 token）
# 下一行的 @name 给这个请求起个名字 "login"，后续请求用 {{login.response.body.token}} 引用它响应里的 token
# 重要：@name 行必须独占一行，名字后面不能跟任何字符（即使是注释），否则名字会被解析成整行内容，{{login.xxx}} 就找不到
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "123456"
}


### ④ 登录失败 —— 错误密码（→ 401）
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "wrong-password"
}


### ⑤ /api/me 不带 token（→ 401 "未登录或 token 格式错误"）
GET {{baseUrl}}/api/me


### ⑥ /api/me 带假 token（→ 401 "token 无效或已过期"，证明签名校验生效）
GET {{baseUrl}}/api/me
Authorization: Bearer this-is-a-fake-token


### ⑦ /api/me 带真 token（→ 200，返回当前用户信息）
# 这一行是 REST Client 的杀手锏：
# {{login.response.body.token}} 自动从上面 ③ 那次登录响应的 body 里取 token 字段
# 前提：你得先成功跑过 ③ 一次（REST Client 会缓存上次响应）
GET {{baseUrl}}/api/me
Authorization: Bearer {{login.response.body.token}}


# ============================================================
# D4 - 客户管理 CRUD
# 注意：所有客户接口都要带 token，前置条件是先跑过上面 ③ 拿到 token
# ============================================================

### ⑧ 新增客户 A（→ 201，返回新增的客户对象，owner_id 自动是当前登录用户）
POST {{baseUrl}}/api/customers
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "张三",
  "company": "字节跳动",
  "level": "A",
  "industry": "互联网",
  "source": "官网注册",
  "stage": "contact",
  "tags": ["重点客户", "北方区"]
}


### ⑨ 新增客户 B（多塞几条数据，列表才有得分页）
POST {{baseUrl}}/api/customers
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "李四",
  "company": "阿里巴巴",
  "level": "B",
  "industry": "电商",
  "stage": "lead"
}


### ⑩ 新增客户 C
POST {{baseUrl}}/api/customers
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "王五",
  "company": "腾讯",
  "level": "C",
  "industry": "游戏",
  "source": "展会",
  "stage": "qualified",
  "tags": ["华南"]
}


### ⑪ 新增校验失败：name 不能为空（→ 400）
POST {{baseUrl}}/api/customers
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "company": "没填姓名的客户"
}


### ⑫ 列表（默认 page=1, pageSize=10）→ 200，data 数组里能看到刚才仨
GET {{baseUrl}}/api/customers
Authorization: Bearer {{login.response.body.token}}


### ⑬ 列表 + 分页（每页 2 条，看第 2 页）
GET {{baseUrl}}/api/customers?page=2&pageSize=2
Authorization: Bearer {{login.response.body.token}}


### ⑭ 列表 + 搜索（关键字 "阿里"，应该只返回李四）
GET {{baseUrl}}/api/customers?keyword=阿里
Authorization: Bearer {{login.response.body.token}}


### ⑮ 详情：取 id=1
GET {{baseUrl}}/api/customers/1
Authorization: Bearer {{login.response.body.token}}


### ⑯ 详情：id 不存在（→ 404）
GET {{baseUrl}}/api/customers/9999
Authorization: Bearer {{login.response.body.token}}


### ⑰ 详情：id 不是数字（→ 400）
GET {{baseUrl}}/api/customers/abc
Authorization: Bearer {{login.response.body.token}}


### ⑱ 编辑客户 id=1（部分更新，只改 stage 和 level）
PUT {{baseUrl}}/api/customers/1
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "stage": "won",
  "level": "A"
}


### ⑲ 删除客户 id=3（→ 200, { success: true }）
DELETE {{baseUrl}}/api/customers/3
Authorization: Bearer {{login.response.body.token}}


### ⑳ 不带 token 访问客户接口（→ 401，证明鉴权中间件生效）
GET {{baseUrl}}/api/customers


# ============================================================
# D6 - 联系人 contacts
# 注意 URL 风格：列表/新增走嵌套，编辑/删除走扁平
# 前置：customerId 这个客户在 customers 表里存在；不存在的话先跑 ⑧ 新增
# ============================================================

# 改这一行就能切换测试的客户 id（比如客户 1 被删了，改成你库里实际存在的 id）
@customerId = 16

### ㉑ 给客户 1 加联系人 A（→ 201）
POST {{baseUrl}}/api/customers/{{customerId}}/contacts
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "采购小王",
  "phone": "13800138001",
  "email": "wang@example.com",
  "position": "采购经理",
  "isPrimary": true
}


### ㉒ 给客户 1 加联系人 B（普通联系人）
POST {{baseUrl}}/api/customers/{{customerId}}/contacts
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "name": "前台小李",
  "phone": "13800138002",
  "position": "前台"
}


### ㉓ 校验失败：name 为空（→ 400）
POST {{baseUrl}}/api/customers/{{customerId}}/contacts
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "phone": "13800138003"
}


### ㉔ 列出客户 1 的联系人（→ 200，主联系人小王在前）
GET {{baseUrl}}/api/customers/{{customerId}}/contacts
Authorization: Bearer {{login.response.body.token}}


### ㉕ 列出不存在客户的联系人（→ 404）
GET {{baseUrl}}/api/customers/9999/contacts
Authorization: Bearer {{login.response.body.token}}


### ㉖ 编辑联系人 1（改 position）
PUT {{baseUrl}}/api/contacts/1
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "position": "采购总监"
}


### ㉗ 删除联系人 2
DELETE {{baseUrl}}/api/contacts/2
Authorization: Bearer {{login.response.body.token}}


# ============================================================
# D6 - 跟进记录 follow_ups
# 追加 only：只有 GET / POST，没有 PUT/DELETE
# ============================================================

### ㉘ 给客户 1 加跟进记录（电话）
POST {{baseUrl}}/api/customers/{{customerId}}/follow-ups
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "type": "call",
  "content": "## 电话沟通\n\n聊了下他们 Q3 的采购计划，**预算 100W**。\n\n下次约视频详谈。",
  "nextAt": "2026-06-15T14:00:00.000Z"
}


### ㉙ 给客户 1 加跟进记录（拜访，无下次时间）
POST {{baseUrl}}/api/customers/{{customerId}}/follow-ups
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "type": "visit",
  "content": "上门拜访，确认了产品 demo 需求。"
}


### ㉚ 校验失败：type 不在枚举里（→ 400）
POST {{baseUrl}}/api/customers/{{customerId}}/follow-ups
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "type": "carrier-pigeon",
  "content": "用信鸽送了张明信片"
}


### ㉛ 列出客户 1 的跟进记录（→ 200，最新的在前）
GET {{baseUrl}}/api/customers/{{customerId}}/follow-ups
Authorization: Bearer {{login.response.body.token}}


# ============================================================
# D7 - 销售商机 deals（销售漏斗看板的数据源）
# 接口全是扁平 URL：/api/deals 和 /api/deals/:id
# 前置：customerId 在 customers 表里存在；用上面 @customerId 这个变量
# ============================================================

### ㉜ 新增商机 A（最少字段，stage 走默认 'lead'）
POST {{baseUrl}}/api/deals
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "title": "ERP 系统采购"
}


### ㉝ 新增商机 B（完整字段，stage='contact'）
POST {{baseUrl}}/api/deals
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "title": "年度技术服务续约",
  "amount": 800000,
  "stage": "contact",
  "probability": 60,
  "expectedCloseAt": "2026-09-30T00:00:00.000Z"
}


### ㉞ 新增商机 C（报价阶段）
POST {{baseUrl}}/api/deals
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "title": "CRM 二期开发",
  "amount": 1200000,
  "stage": "quote",
  "probability": 80
}


### ㉟ 校验失败：title 为空（→ 400）
POST {{baseUrl}}/api/deals
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "customerId": {{customerId}},
  "title": ""
}


### ㊱ 列表（默认排除 lost）→ 200，看到上面 3 条
GET {{baseUrl}}/api/deals
Authorization: Bearer {{login.response.body.token}}


### ㊲ 列表筛 stage=lead（应该只看到 ㉜ 那条）
GET {{baseUrl}}/api/deals?stage=lead
Authorization: Bearer {{login.response.body.token}}


### ㊳ 详情：取 id=1（不存在就改成实际 id）
GET {{baseUrl}}/api/deals/1
Authorization: Bearer {{login.response.body.token}}


### ㊴ 拖拽看板模拟：id=1 从 lead 拖到 quote（PUT 只传 stage 一个字段）
PUT {{baseUrl}}/api/deals/1
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "stage": "quote"
}


### ㊵ 标记丢失：id=2 改 stage='lost'（业务上点"标记丢失"按钮就是发这个请求）
PUT {{baseUrl}}/api/deals/2
Authorization: Bearer {{login.response.body.token}}
Content-Type: application/json

{
  "stage": "lost"
}


### ㊶ 再列一次（确认 id=2 不在默认列表里 → 证明 lost 被隐藏）
GET {{baseUrl}}/api/deals
Authorization: Bearer {{login.response.body.token}}


### ㊷ 单查 lost：?stage=lost（应该能看到 id=2）
GET {{baseUrl}}/api/deals?stage=lost
Authorization: Bearer {{login.response.body.token}}


# ============================================================
# D10 - 仪表盘统计接口
# 业务约定：admin / viewer 看全公司，sales 只看自己负责的
# ============================================================

### ㊸ 4 个核心指标
GET {{baseUrl}}/api/stats/overview
Authorization: Bearer {{login.response.body.token}}


### ㊹ 本月按天新增客户数（折线图数据）
GET {{baseUrl}}/api/stats/customer-trend
Authorization: Bearer {{login.response.body.token}}


### ㊺ 商机漏斗（lead/contact/quote/won 4 个 stage 的数量）
GET {{baseUrl}}/api/stats/deal-funnel
Authorization: Bearer {{login.response.body.token}}


### ㊻ 销售排行 Top 10（仅 won 商机的总金额）
GET {{baseUrl}}/api/stats/sales-rank
Authorization: Bearer {{login.response.body.token}}


# ============================================================
# D12 - 演示数据（一键造一批客户 / 联系人 / 跟进 / 商机）
# ============================================================
#
# 用法：从 ③ 登录开始，按顺序点 Send Request
# 每个客户响应会被 @name 捕获，后续 contacts / followUps / deals 引用 {{xxx.response.body.id}}
# 不需要手填 customerId
#
# 数据规划：
#   5 个客户（admin owner，覆盖不同 stage / level / industry）
#   每客户 2 联系人（共 ~8）
#   3 客户各 2 跟进（共 6）
#   8 个商机（lead 2 / contact 2 / quote 2 / won 2，给仪表盘漏斗 + 排行榜留素材）


