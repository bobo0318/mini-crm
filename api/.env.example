# 环境变量模板文件（会进 git，仅作示范，不要写真实密钥）
# 用法：cp .env.example .env，然后把下面的值改成你自己的

# ============== JWT ==============
# JWT 签名密钥；安全要求：>= 32 字符 + 随机
# 生产环境用 `openssl rand -base64 32` 生成
JWT_SECRET=please-change-me-in-real-env

# JWT 过期时间，jsonwebtoken 格式："7d" = 7 天, "1h" = 1 小时
JWT_EXPIRES_IN=7d

# ============== Database (D12) ==============
# 本地：file: 协议 + 相对路径（libsql client 支持本地 SQLite 文件）
# 生产 Turso：libsql://xxx.turso.io + DATABASE_AUTH_TOKEN
DATABASE_URL=file:./mini-crm.db

# Turso 远程数据库的 auth token，本地文件不需要
# DATABASE_AUTH_TOKEN=

# ============== CORS (D12) ==============
# 允许调用本后端的前端域名；多个用逗号分隔
# 本地：http://localhost:5173
# 生产：https://your-vercel-app.vercel.app
CORS_ORIGIN=http://localhost:5173
