# 环境变量模板文件（会进 git，仅作示范，不要写真实密钥）
# 用法：cp .env.example .env，然后把下面的值改成你自己的

# JWT 签名密钥
# 用途：服务器给 token 签名 + 验签都用它
# 安全要求：足够长（>= 32 字符）+ 随机；生产环境用 `openssl rand -base64 32` 生成
JWT_SECRET=please-change-me-in-real-env

# JWT 过期时间，单位是 jsonwebtoken 的字符串格式："7d" = 7 天, "1h" = 1 小时, "30m" = 30 分钟
JWT_EXPIRES_IN=7d
